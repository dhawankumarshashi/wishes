<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Someone Special ❤️</title>
    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background:linear-gradient(135deg,#ff9a9e,#fad0c4);
        }

        .card{
            background:white;
            padding:40px;
            border-radius:20px;
            text-align:center;
            width:400px;
            box-shadow:0 10px 30px rgba(0,0,0,0.2);
        }

        h1{
            color:#ff4d6d;
            margin-bottom:15px;
        }

        p{
            color:#444;
            line-height:1.7;
            margin-bottom:20px;
        }

        button{
            padding:12px 25px;
            border:none;
            border-radius:30px;
            background:#ff4d6d;
            color:white;
            font-size:16px;
            cursor:pointer;
        }

        button:hover{
            transform:scale(1.05);
        }

        #message{
            margin-top:20px;
            color:#ff4d6d;
            font-weight:bold;
            font-size:18px;
        }
    </style>
</head>
<body>

<div class="card">
    <h1>❤️ Hey You ❤️</h1>

    <p>
        This isn't a website.<br>
        It's just a small reminder that you're special,
        appreciated, and one of my favorite people.
    </p>

    <button onclick="showMessage()">Click Here ✨</button>

    <div id="message"></div>
</div>

<script>
function showMessage(){
    document.getElementById("message").innerHTML =
    "No matter how many people I meet, there's something uniquely special about you. ❤️";
}
</script>

</body>
</html>